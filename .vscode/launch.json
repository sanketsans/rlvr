{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RLVR: local CPU (tiny grpo)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/train_grpo.py",
      "python": "/Users/sanket.thakur/miniconda3/envs/rlvr/bin/python",
      "args": [
        "--config", "configs/debug_grpo_cpu.yaml",
        "--no-wandb"
      ],
      "env": {
        "CUDA_VISIBLE_DEVICES": "",
        "RLVR_DEBUG_FP32HEAD": "1"
      },
      "justMyCode": false,
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "RLVR: local CPU (pass@k eval)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/pass_at_k.py",
      "args": [
        "--config", "configs/phase0_passk.yaml",
        "--max-samples", "2",
        "--no-wandb"
      ],
      "env": { "CUDA_VISIBLE_DEVICES": "" },
      "justMyCode": false,
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "RLVR: attach to Sky pod :5678",
      "type": "debugpy",
      "request": "attach",
      "connect": { "host": "127.0.0.1", "port": 5678 },
      "justMyCode": false,
      "pathMappings": [
        { "localRoot": "${workspaceFolder}", "remoteRoot": "/home/sky/sky_workdir" }
      ]
    }
  ]
}
